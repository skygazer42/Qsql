{
  "catalog_version": "2026-06-15",
  "dataset_id": "online_retail",
  "tables": [
    {
      "key": "online_retail_wide",
      "label": "线上零售交易宽表",
      "physical_table": "online_retail_orders",
      "description": "UCI Online Retail 真实线上零售交易明细，按发票商品行粒度展开",
      "default_time_dimension_key": "invoice_date"
    }
  ],
  "metrics": [
    {
      "key": "revenue",
      "label": "销售额",
      "table_key": "online_retail_wide",
      "field": "revenue",
      "aggregation": "sum",
      "supported_dimension_keys": [
        "country",
        "product",
        "invoice_date",
        "invoice_month"
      ],
      "default_time_dimension_key": "invoice_date",
      "allowed_version_keys": [
        "valid_revenue"
      ],
      "description": "按数量 * 单价计算的交易行金额"
    },
    {
      "key": "quantity",
      "label": "销售数量",
      "table_key": "online_retail_wide",
      "field": "quantity",
      "aggregation": "sum",
      "supported_dimension_keys": [
        "country",
        "product",
        "invoice_date",
        "invoice_month"
      ],
      "default_time_dimension_key": "invoice_date",
      "allowed_version_keys": [
        "valid_quantity"
      ]
    },
    {
      "key": "invoice_count",
      "label": "发票数",
      "table_key": "online_retail_wide",
      "field": "invoice_no",
      "aggregation": "count_distinct",
      "supported_dimension_keys": [
        "country",
        "product",
        "invoice_date",
        "invoice_month"
      ],
      "default_time_dimension_key": "invoice_date",
      "allowed_version_keys": [
        "valid_invoice_count"
      ]
    }
  ],
  "dimensions": [
    {
      "key": "country",
      "label": "国家",
      "table_key": "online_retail_wide",
      "field": "country",
      "kind": "categorical",
      "operators": [
        "eq",
        "in"
      ]
    },
    {
      "key": "product",
      "label": "商品",
      "table_key": "online_retail_wide",
      "field": "description",
      "kind": "categorical",
      "operators": [
        "eq",
        "in"
      ]
    },
    {
      "key": "invoice_date",
      "label": "发票日期",
      "table_key": "online_retail_wide",
      "field": "invoice_date",
      "kind": "time",
      "operators": [
        "between",
        "gte",
        "lte"
      ]
    },
    {
      "key": "invoice_month",
      "label": "发票月份",
      "table_key": "online_retail_wide",
      "field": "invoice_month",
      "kind": "time",
      "operators": [
        "between",
        "gte",
        "lte",
        "eq",
        "in"
      ]
    },
    {
      "key": "is_cancellation",
      "label": "是否取消订单",
      "table_key": "online_retail_wide",
      "field": "is_cancellation",
      "kind": "categorical",
      "operators": [
        "eq"
      ]
    }
  ],
